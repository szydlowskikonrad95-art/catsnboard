# ── Nagłówek wtyczki (lista wtyczek) ──
msgid "PNB Polish Version (AI)"
msgstr "PNB Polska Wersja (AI)"

msgid "Polish version of the site with a PL/EN switcher: the \"Translate site\" button translates everything with Claude AI, and every page save auto-translates the changes. Visitors get ready-made Polish (zero AI calls per visit)."
msgstr "Polska wersja strony z przełącznikiem PL/EN: przycisk „Przetłumacz witrynę” tłumaczy całość przez Claude AI, a każdy zapis strony automatycznie dotłumacza zmiany. Goście dostają gotowy polski (zero AI przy wejściu)."

# ── Panel ustawień ──
msgid "Settings saved."
msgstr "Ustawienia zapisane."

msgid "No permission."
msgstr "Brak uprawnień."

msgid "Home page"
msgstr "Strona główna"

msgid "PNB Auto PL — site translation (Claude)"
msgstr "PNB Auto PL — tłumaczenie strony (Claude)"

msgid "%s detected."
msgstr "Wykryto %s."

msgid "Two language systems on one site may clash. Recommendation: use ONE — either this plugin or %s (deactivate the other)."
msgstr "Dwa systemy językowe na jednej stronie mogą się gryźć. Zalecenie: używaj JEDNEGO — albo tej wtyczki, albo %s (tamten wyłącz)."

msgid "Anthropic API key"
msgstr "Klucz API Anthropic"

msgid "Key saved (ends with %s). Enter a new one only to change it."
msgstr "Klucz zapisany (kończy się na %s). Wpisz nowy tylko żeby zmienić."

msgid "Paste your key from console.anthropic.com."
msgstr "Wklej swój klucz z console.anthropic.com."

msgid "Model"
msgstr "Model"

msgid "Haiku 4.5 — fast & cheap (recommended)"
msgstr "Haiku 4.5 — tani, szybki (zalecany)"

msgid "Sonnet 5 — better wording, pricier"
msgstr "Sonnet 5 — lepszy język, drożej"

msgid "Daily character limit"
msgstr "Dzienny limit znaków"

msgid "Cost safety valve: above the limit, translation pauses until tomorrow."
msgstr "Bezpiecznik kosztu: powyżej limitu tłumaczenie się zatrzymuje do jutra."

msgid "Used today: <strong>%s</strong> characters."
msgstr "Dziś zużyte: <strong>%s</strong> znaków."

msgid "Save settings"
msgstr "Zapisz ustawienia"

msgid "Test connection"
msgstr "Testuj połączenie"

msgid "Site translation"
msgstr "Tłumaczenie witryny"

msgid "Dictionary: <strong>%1$s</strong> translated phrases (%2$s corrected by hand). Pages to translate: <strong>%3$s</strong>."
msgstr "Słownik: <strong>%1$s</strong> przetłumaczonych fraz (%2$s poprawionych ręcznie). Stron do przetłumaczenia: <strong>%3$s</strong>."

msgid "Dictionary: <strong>%1$s</strong> translated phrases (%2$s corrected by hand). Site pages: %3$s, awaiting translation: <strong>%4$s</strong>."
msgstr "Słownik: <strong>%1$s</strong> przetłumaczonych fraz (%2$s poprawionych ręcznie). Stron w witrynie: %3$s, do przetłumaczenia: <strong>%4$s</strong>."

msgid "Translate site to Polish"
msgstr "Przetłumacz witrynę na polski"

# ── Postęp tłumaczenia (JS) ──
msgid "Works"
msgstr "Działa"

msgid "error"
msgstr "błąd"

msgid "Page"
msgstr "Strona"

msgid "segments:"
msgstr "segmentów:"

msgid "from cache:"
msgstr "z pamięci:"

msgid "new:"
msgstr "nowych:"

msgid "skipped:"
msgstr "pominiętych:"

msgid "Daily character limit reached — the rest tomorrow (or raise the limit)."
msgstr "Dzienny limit znaków wyczerpany — reszta jutro (albo podnieś limit)."

msgid "Done. New translations:"
msgstr "Gotowe. Nowych tłumaczeń:"

msgid "Check the site with the PL switcher."
msgstr "Sprawdź stronę z przełącznikiem PL."

# ── Tłumaczenie po zapisie / notki ──
msgid "Empty page HTML."
msgstr "Pusty HTML strony."

msgid "Exception: "
msgstr "Wyjątek: "

msgid "Polish version updated"
msgstr "Polska wersja zaktualizowana"

msgid "new translations"
msgstr "nowych tłumaczeń"

msgid "%d page changed since the last translation"
msgid_plural "%d pages changed since the last translation"
msgstr[0] "%d strona zmieniona po ostatnim tłumaczeniu"
msgstr[1] "%d strony zmienione po ostatnim tłumaczeniu"
msgstr[2] "%d stron zmienionych po ostatnim tłumaczeniu"

msgid "translate again"
msgstr "przetłumacz ponownie"

# ── Silnik Claude ──
msgid "No Anthropic API key set — add it in settings."
msgstr "Nie ustawiono klucza API Anthropic — dodaj go w ustawieniach."

msgid "Claude returned no translation."
msgstr "Claude nie zwrócił tłumaczenia."

msgid "All fragments already cached."
msgstr "Wszystkie fragmenty już w pamięci podręcznej."

msgid "Request failed."
msgstr "Żądanie nie powiodło się."
